---
interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Yoav's CodeX Projects",
  description = "A minimalist index of Yoav's shipped apps with publication dates and links."
} = Astro.props;

const pageTitle = title;
const pageDescription = description;
const pageUrl = new URL(Astro.url.pathname, Astro.site ?? 'https://example-portfolio.vercel.app').toString();
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />

    <title>{pageTitle}</title>
    <meta name="description" content={pageDescription} />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:url" content={pageUrl} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={pageDescription} />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <style is:global>
      :root {
        color-scheme: dark;
        --bg: #0c0c10;
        --panel: #121217;
        --text: #efedf5;
        --text-soft: #b9b4c6;
        --muted: #9a95ab;
        --border: #302b3c;
        --accent: #5b4a8b;
        --accent-hover: #4b3d73;
      }

      * {
        box-sizing: border-box;
      }

      body {
        margin: 0;
        font-family: "Space Grotesk", "Avenir Next", "Segoe UI", sans-serif;
        background:
          radial-gradient(800px 360px at 8% -8%, rgba(99, 75, 148, 0.2), transparent 58%),
          linear-gradient(145deg, #0c0c10 0%, #0e0e13 45%, #11111a 100%);
        color: var(--text);
        min-height: 100vh;
      }

      a {
        color: inherit;
      }
    </style>
  </head>
  <body>
    <slot />
  </body>
</html>
