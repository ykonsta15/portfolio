---
interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Yoav's CodeX Projects",
  description = "Track Yoav's shipped apps, publication milestones, and build insights in one place."
} = Astro.props;

const pageTitle = title;
const pageDescription = description;
const pageUrl = new URL(Astro.url.pathname, Astro.site ?? 'https://example-portfolio.vercel.app').toString();
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />

    <title>{pageTitle}</title>
    <meta name="description" content={pageDescription} />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:url" content={pageUrl} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={pageDescription} />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <style is:global>
      :root {
        color-scheme: dark;
        --bg: #05050a;
        --panel: #09090f;
        --text: #f5f3ff;
        --text-soft: #c8c3d6;
        --muted: #a3a0b6;
        --border: rgba(167, 139, 250, 0.25);
        --accent: #9333ea;
        --accent-hover: #7e22ce;
      }

      * {
        box-sizing: border-box;
      }

      body {
        margin: 0;
        font-family: "Space Grotesk", "Avenir Next", "Segoe UI", sans-serif;
        background:
          radial-gradient(1000px 460px at 10% -10%, rgba(147, 51, 234, 0.42), transparent 60%),
          radial-gradient(900px 420px at 100% 0%, rgba(124, 58, 237, 0.34), transparent 58%),
          linear-gradient(145deg, #040408 0%, #09070f 45%, #0f0820 100%);
        color: var(--text);
        min-height: 100vh;
      }

      a {
        color: inherit;
      }
    </style>
  </head>
  <body>
    <slot />
  </body>
</html>
