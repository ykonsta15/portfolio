---
import BaseLayout from '../layouts/BaseLayout.astro';
import ProjectCard from '../components/ProjectCard.astro';
import projects from '../data/projects.json';

const sortedProjects = [...projects].sort(
  (a, b) => new Date(b.publishedAt).getTime() - new Date(a.publishedAt).getTime()
);
---

<BaseLayout
  title="Yoav's CodeX Projects"
  description="A minimalist index of Yoav's shipped apps with publication dates and links."
>
  <main class="container">
    <header class="hero">
      <h1>Yoav's CodeX Projects</h1>
      <p>Welcome! This page is where I post the apps I build as I continue to learn how to use CodeX. Hopefully they will get better and more complex over time, but in the meantime feel free to scroll through what I've done so far.</p>
    </header>

    <section class="controls" aria-label="Search projects">
      <input
        id="searchInput"
        type="search"
        placeholder="Search by title or description"
        aria-label="Search projects"
      />
    </section>

    <p id="resultsCount" class="results-count">Showing {projects.length} projects</p>

    <section id="projectsGrid" class="grid" aria-live="polite">
      {sortedProjects.map((project) => <ProjectCard project={project} />)}
    </section>
  </main>

  <script>
    const searchInput = document.querySelector('#searchInput');
    const cards = Array.from(document.querySelectorAll('[data-project]'));
    const countEl = document.querySelector('#resultsCount');

    const updateProjects = () => {
      const searchTerm = (searchInput?.value || '').trim().toLowerCase();

      let visibleCount = 0;

      cards.forEach((card) => {
        const title = card.getAttribute('data-title') || '';
        const description = card.getAttribute('data-description') || '';

        const visible =
          !searchTerm ||
          title.includes(searchTerm) ||
          description.includes(searchTerm);
        card.style.display = visible ? '' : 'none';
        if (visible) visibleCount += 1;
      });

      if (countEl) {
        countEl.textContent = `Showing ${visibleCount} project${visibleCount === 1 ? '' : 's'}`;
      }
    };

    searchInput?.addEventListener('input', updateProjects);
  </script>

  <style>
    .container {
      width: min(1100px, calc(100% - 2rem));
      margin: 0 auto;
      padding: 2.5rem 0 3rem;
    }

    .hero {
      margin-bottom: 1.1rem;
    }

    .hero h1 {
      margin: 0;
      font-size: clamp(2rem, 4vw, 2.9rem);
      line-height: 1.2;
    }

    .hero p {
      margin: 0.55rem 0 0;
      color: var(--text-soft);
      max-width: 60ch;
    }

    .controls {
      display: grid;
      grid-template-columns: 1fr;
      gap: 0.7rem;
      margin-bottom: 0.8rem;
    }

    input {
      width: 100%;
      border: 1px solid #3b3648;
      border-radius: 10px;
      padding: 0.65rem 0.8rem;
      font-size: 0.95rem;
      background: rgba(13, 13, 17, 0.9);
      color: var(--text);
    }

    input::placeholder {
      color: #8e899f;
    }

    .results-count {
      margin: 0 0 1rem;
      color: var(--muted);
      font-size: 0.95rem;
    }

    .grid {
      display: grid;
      gap: 1rem;
      grid-template-columns: repeat(1, minmax(0, 1fr));
    }

    @media (min-width: 680px) {
      .grid {
        grid-template-columns: repeat(2, minmax(0, 1fr));
      }
    }

    @media (min-width: 1024px) {
      .grid {
        grid-template-columns: repeat(3, minmax(0, 1fr));
      }
    }
  </style>
</BaseLayout>
