---
interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Portfolio | Deployed Apps',
  description = 'A central portfolio listing deployed apps with links to live demos and repositories.'
} = Astro.props;

const pageTitle = title;
const pageDescription = description;
const pageUrl = new URL(Astro.url.pathname, Astro.site ?? 'https://example-portfolio.vercel.app').toString();
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />

    <title>{pageTitle}</title>
    <meta name="description" content={pageDescription} />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:url" content={pageUrl} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={pageDescription} />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <style is:global>
      :root {
        color-scheme: light;
        --bg: #f6f8fb;
        --panel: #ffffff;
        --text: #101828;
        --muted: #475467;
        --border: #d0d5dd;
        --accent: #1d4ed8;
        --accent-hover: #1e40af;
        --chip: #eef2ff;
      }

      * {
        box-sizing: border-box;
      }

      body {
        margin: 0;
        font-family: "Avenir Next", Avenir, "Segoe UI", Helvetica, Arial, sans-serif;
        background: radial-gradient(circle at 10% 20%, #ffffff 0%, var(--bg) 50%, #edf2f7 100%);
        color: var(--text);
        min-height: 100vh;
      }

      a {
        color: inherit;
      }
    </style>
  </head>
  <body>
    <slot />
  </body>
</html>
