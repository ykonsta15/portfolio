---
import BaseLayout from '../layouts/BaseLayout.astro';
import ProjectCard from '../components/ProjectCard.astro';
import projects from '../data/projects.json';

const sortedProjects = [...projects].sort(
  (a, b) => new Date(b.publishedAt).getTime() - new Date(a.publishedAt).getTime()
);
const totalProjects = sortedProjects.length;
const avgProgress = Math.round(
  sortedProjects.reduce((acc, project) => acc + project.progress, 0) / Math.max(totalProjects, 1)
);
const inProgressCount = sortedProjects.filter((project) => project.progress < 100).length;
---

<BaseLayout
  title="Yoav's CodeX Projects"
  description="Track live CodeX projects with publication dates, build insights, and ongoing progress."
>
  <main class="container">
    <header class="hero">
      <p class="eyebrow">Portfolio Dashboard</p>
      <h1>Yoav's CodeX Projects</h1>
      <p>Futuristic progress board for shipped apps, with the insight behind each build.</p>
    </header>

    <section class="stats" aria-label="Progress overview">
      <article class="stat">
        <span class="label">Projects</span>
        <strong>{totalProjects}</strong>
      </article>
      <article class="stat">
        <span class="label">In progress</span>
        <strong>{inProgressCount}</strong>
      </article>
      <article class="stat">
        <span class="label">Average completion</span>
        <strong>{avgProgress}%</strong>
      </article>
    </section>

    <section class="controls" aria-label="Search projects">
      <input
        id="searchInput"
        type="search"
        placeholder="Search by title, description, or insight note"
        aria-label="Search projects"
      />
    </section>

    <p id="resultsCount" class="results-count">Showing {projects.length} projects</p>

    <section id="projectsGrid" class="grid" aria-live="polite">
      {sortedProjects.map((project) => <ProjectCard project={project} />)}
    </section>
  </main>

  <script>
    const searchInput = document.querySelector('#searchInput');
    const cards = Array.from(document.querySelectorAll('[data-project]'));
    const countEl = document.querySelector('#resultsCount');

    const updateProjects = () => {
      const searchTerm = (searchInput?.value || '').trim().toLowerCase();

      let visibleCount = 0;

      cards.forEach((card) => {
        const title = card.getAttribute('data-title') || '';
        const description = card.getAttribute('data-description') || '';
        const insight = card.getAttribute('data-insight') || '';

        const visible =
          !searchTerm ||
          title.includes(searchTerm) ||
          description.includes(searchTerm) ||
          insight.includes(searchTerm);
        card.style.display = visible ? '' : 'none';
        if (visible) visibleCount += 1;
      });

      if (countEl) {
        countEl.textContent = `Showing ${visibleCount} project${visibleCount === 1 ? '' : 's'}`;
      }
    };

    searchInput?.addEventListener('input', updateProjects);
  </script>

  <style>
    .container {
      width: min(1100px, calc(100% - 2rem));
      margin: 0 auto;
      padding: 2.5rem 0 3rem;
    }

    .hero {
      margin-bottom: 1rem;
    }

    .eyebrow {
      margin: 0;
      color: #d8b4fe;
      font-family: "IBM Plex Mono", "SF Mono", Menlo, monospace;
      text-transform: uppercase;
      letter-spacing: 0.12em;
      font-size: 0.72rem;
    }

    .hero h1 {
      margin: 0;
      font-size: clamp(2rem, 4vw, 2.9rem);
      line-height: 1.2;
    }

    .hero p {
      margin: 0.55rem 0 0;
      color: var(--text-soft);
      max-width: 60ch;
    }

    .stats {
      display: grid;
      grid-template-columns: repeat(1, minmax(0, 1fr));
      gap: 0.7rem;
      margin-bottom: 1rem;
    }

    .stat {
      border: 1px solid rgba(196, 181, 253, 0.25);
      background: rgba(15, 12, 28, 0.75);
      border-radius: 12px;
      padding: 0.7rem 0.8rem;
      display: grid;
      gap: 0.3rem;
    }

    .stat .label {
      color: var(--muted);
      font-size: 0.78rem;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      font-family: "IBM Plex Mono", "SF Mono", Menlo, monospace;
    }

    .stat strong {
      font-size: 1.5rem;
    }

    .controls {
      display: grid;
      grid-template-columns: 1fr;
      gap: 0.7rem;
      margin-bottom: 0.8rem;
    }

    input {
      width: 100%;
      border: 1px solid rgba(216, 180, 254, 0.36);
      border-radius: 10px;
      padding: 0.65rem 0.8rem;
      font-size: 0.95rem;
      background: rgba(8, 7, 15, 0.7);
      color: var(--text);
    }

    input::placeholder {
      color: #9e92b8;
    }

    .results-count {
      margin: 0 0 1rem;
      color: var(--muted);
      font-size: 0.95rem;
    }

    .grid {
      display: grid;
      gap: 1rem;
      grid-template-columns: repeat(1, minmax(0, 1fr));
    }

    @media (min-width: 680px) {
      .stats {
        grid-template-columns: repeat(3, minmax(0, 1fr));
      }

      .grid {
        grid-template-columns: repeat(2, minmax(0, 1fr));
      }
    }

    @media (min-width: 1024px) {
      .grid {
        grid-template-columns: repeat(3, minmax(0, 1fr));
      }
    }
  </style>
</BaseLayout>
