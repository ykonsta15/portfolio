---
interface Project {
  title: string;
  description: string;
  publishedAt: string;
  appUrl: string;
  repoUrl: string;
}

interface Props {
  project: Project;
}

const { project } = Astro.props;
const publishedLabel = new Date(project.publishedAt).toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'short',
  day: 'numeric'
});
---

<article
  class="card"
  data-project
  data-title={project.title.toLowerCase()}
  data-description={project.description.toLowerCase()}
>
  <p class="date">Published {publishedLabel}</p>
  <h2>{project.title}</h2>
  <p>{project.description}</p>

  <div class="actions">
    <a href={project.appUrl} target="_blank" rel="noreferrer noopener" class="btn btn-primary">Open app</a>
    <a href={project.repoUrl} target="_blank" rel="noreferrer noopener" class="btn btn-secondary">View repo</a>
  </div>
</article>

<style>
  .card {
    background: rgba(18, 18, 22, 0.95);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 1rem;
    display: flex;
    flex-direction: column;
    gap: 0.7rem;
  }

  .date {
    margin: 0;
    font-family: "IBM Plex Mono", "SF Mono", Menlo, monospace;
    letter-spacing: 0.02em;
    font-size: 0.74rem;
    color: var(--muted);
  }

  h2 {
    margin: 0;
    font-size: 1.2rem;
    line-height: 1.3;
  }

  p {
    margin: 0;
    color: var(--text-soft);
    line-height: 1.5;
  }

  .actions {
    margin-top: auto;
    display: flex;
    gap: 0.6rem;
    flex-wrap: wrap;
  }

  .btn {
    text-decoration: none;
    border-radius: 10px;
    padding: 0.5rem 0.75rem;
    font-weight: 600;
    font-size: 0.9rem;
    border: 1px solid transparent;
  }

  .btn-primary {
    background: #5b4a8b;
    color: #ffffff;
  }

  .btn-primary:hover {
    background: #4b3d73;
  }

  .btn-secondary {
    background: transparent;
    color: #d6d0e5;
    border-color: #4b4458;
  }

  .btn-secondary:hover {
    background: rgba(255, 255, 255, 0.04);
  }
</style>
