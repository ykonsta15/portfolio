---
interface Project {
  title: string;
  description: string;
  publishedAt: string;
  insight: string;
  progress: number;
  appUrl: string;
  repoUrl: string;
}

interface Props {
  project: Project;
}

const { project } = Astro.props;
const publishedLabel = new Date(project.publishedAt).toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'short',
  day: 'numeric'
});
---

<article
  class="card"
  data-project
  data-title={project.title.toLowerCase()}
  data-description={project.description.toLowerCase()}
  data-insight={project.insight.toLowerCase()}
>
  <p class="date">Published {publishedLabel}</p>
  <h2>{project.title}</h2>
  <p>{project.description}</p>

  <section class="insight" aria-label="Insight note">
    <p class="insight-label">Build insight</p>
    <p class="insight-text">{project.insight}</p>
  </section>

  <section class="progress" aria-label="Build progress">
    <div class="progress-head">
      <span>Progress</span>
      <strong>{project.progress}%</strong>
    </div>
    <div class="progress-track">
      <div class="progress-fill" style={`width: ${project.progress}%`} />
    </div>
  </section>

  <div class="actions">
    <a href={project.appUrl} target="_blank" rel="noreferrer noopener" class="btn btn-primary">Open app</a>
    <a href={project.repoUrl} target="_blank" rel="noreferrer noopener" class="btn btn-secondary">View repo</a>
  </div>
</article>

<style>
  .card {
    background: linear-gradient(165deg, rgba(14, 10, 26, 0.94), rgba(9, 8, 16, 0.92));
    border: 1px solid var(--border);
    border-radius: 16px;
    padding: 1.1rem;
    display: flex;
    flex-direction: column;
    gap: 0.8rem;
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.06), 0 10px 30px rgba(0, 0, 0, 0.35);
  }

  .date {
    margin: 0;
    font-family: "IBM Plex Mono", "SF Mono", Menlo, monospace;
    letter-spacing: 0.02em;
    font-size: 0.74rem;
    color: var(--muted);
  }

  h2 {
    margin: 0;
    font-size: 1.2rem;
    line-height: 1.3;
  }

  p {
    margin: 0;
    color: var(--text-soft);
    line-height: 1.5;
  }

  .insight {
    border: 1px solid rgba(183, 148, 244, 0.28);
    background: rgba(109, 40, 217, 0.14);
    border-radius: 12px;
    padding: 0.7rem 0.75rem;
  }

  .insight-label {
    margin: 0;
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--muted);
    font-family: "IBM Plex Mono", "SF Mono", Menlo, monospace;
  }

  .insight-text {
    margin-top: 0.35rem;
    color: var(--text);
  }

  .progress {
    display: grid;
    gap: 0.4rem;
  }

  .progress-head {
    display: flex;
    justify-content: space-between;
    align-items: center;
    color: var(--muted);
    font-size: 0.82rem;
    font-family: "IBM Plex Mono", "SF Mono", Menlo, monospace;
  }

  .progress-head strong {
    color: var(--text);
    font-size: 0.85rem;
  }

  .progress-track {
    height: 9px;
    width: 100%;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.08);
    overflow: hidden;
    border: 1px solid rgba(255, 255, 255, 0.08);
  }

  .progress-fill {
    height: 100%;
    background: linear-gradient(90deg, #7e22ce, #c084fc);
    box-shadow: 0 0 14px rgba(192, 132, 252, 0.65);
  }

  .actions {
    margin-top: auto;
    display: flex;
    gap: 0.6rem;
    flex-wrap: wrap;
  }

  .btn {
    text-decoration: none;
    border-radius: 10px;
    padding: 0.5rem 0.75rem;
    font-weight: 600;
    font-size: 0.9rem;
    border: 1px solid transparent;
  }

  .btn-primary {
    background: linear-gradient(120deg, #7e22ce, #9333ea);
    color: #ffffff;
  }

  .btn-primary:hover {
    background: linear-gradient(120deg, #6b21a8, #7e22ce);
  }

  .btn-secondary {
    background: rgba(255, 255, 255, 0.02);
    color: #e9d5ff;
    border-color: rgba(216, 180, 254, 0.32);
  }

  .btn-secondary:hover {
    background: rgba(147, 51, 234, 0.12);
  }
</style>
