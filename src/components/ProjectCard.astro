---
interface Project {
  title: string;
  description: string;
  tags: string[];
  appUrl: string;
  repoUrl: string;
}

interface Props {
  project: Project;
}

const { project } = Astro.props;
---

<article class="card" data-project data-tags={project.tags.join(',').toLowerCase()} data-title={project.title.toLowerCase()} data-description={project.description.toLowerCase()}>
  <h2>{project.title}</h2>
  <p>{project.description}</p>

  <ul class="tags" aria-label="Project tags">
    {project.tags.map((tag) => <li>{tag}</li>)}
  </ul>

  <div class="actions">
    <a href={project.appUrl} target="_blank" rel="noreferrer noopener" class="btn btn-primary">Open app</a>
    <a href={project.repoUrl} target="_blank" rel="noreferrer noopener" class="btn btn-secondary">View repo</a>
  </div>
</article>

<style>
  .card {
    background: var(--panel);
    border: 1px solid var(--border);
    border-radius: 14px;
    padding: 1rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  h2 {
    margin: 0;
    font-size: 1.2rem;
    line-height: 1.3;
  }

  p {
    margin: 0;
    color: var(--muted);
    line-height: 1.5;
  }

  .tags {
    margin: 0;
    padding: 0;
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }

  .tags li {
    background: var(--chip);
    color: #1e3a8a;
    border: 1px solid #c7d2fe;
    border-radius: 999px;
    padding: 0.2rem 0.55rem;
    font-size: 0.8rem;
  }

  .actions {
    margin-top: auto;
    display: flex;
    gap: 0.6rem;
    flex-wrap: wrap;
  }

  .btn {
    text-decoration: none;
    border-radius: 8px;
    padding: 0.5rem 0.75rem;
    font-weight: 600;
    font-size: 0.9rem;
    border: 1px solid transparent;
  }

  .btn-primary {
    background: var(--accent);
    color: #ffffff;
  }

  .btn-primary:hover {
    background: var(--accent-hover);
  }

  .btn-secondary {
    background: #ffffff;
    color: #1d4ed8;
    border-color: #bfdbfe;
  }

  .btn-secondary:hover {
    background: #eff6ff;
  }
</style>
